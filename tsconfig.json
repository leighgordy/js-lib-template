{
  "compilerOptions": {
     "outDir": "./dist",
     "rootDir": "./src",
     "target": "esnext",
     "module": "nodenext",
     "rewriteRelativeImportExtensions": true,
     "erasableSyntaxOnly": true,
     "verbatimModuleSyntax": true,
     "sourceMap": true,
     "declaration": true
  },
  "exclude": [
    "**/*.spec.ts",
  ],
}